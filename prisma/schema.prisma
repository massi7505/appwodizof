// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ===================== SETTINGS =====================
model SiteSettings {
  id               Int     @id @default(1)
  siteName         String  @default("Woodiz Paris 15")
  siteSlogan       String? @default("Pizza artisanale au feu de bois")
  logoUrl          String?
  faviconUrl       String?
  defaultLanguage  String  @default("fr")
  homePage         String  @default("linktree") // "linktree" | "menu"
  primaryColor     String  @default("#F59E0B")
  secondaryColor   String  @default("#1F2937")
  accentColor      String  @default("#EF4444")
  backgroundColor  String  @default("#111827")
  textColor        String  @default("#FFFFFF")
  googleMapsUrl    String?
  googleReviewsUrl String?
  instagramUrl     String?
  phoneNumber      String?
  address          String?
  metaTitle        String?
  metaDescription  String?
  metaKeywords     String?
  metaImageUrl     String?
  enabledLocales   String?  @default("[\"fr\",\"en\",\"it\",\"es\"]")
  showFeatured     Boolean  @default(true)
  showWeekSpecial  Boolean  @default(true)
  featuredTitles   String?  // JSON {"fr":"...","en":"...","it":"...","es":"..."}
  weekTitles       String?  // JSON {"fr":"...","en":"...","it":"...","es":"..."}
  defaultCategoryId Int?    // ID of the category shown by default in the menu tabs
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("site_settings")
}

// ===================== OPENING HOURS =====================
model OpeningHours {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int     // 0=Mon, 1=Tue, ..., 6=Sun
  dayName   String  // "Lundi", "Mardi", etc.
  isOpen    Boolean @default(true)
  slots     String  // JSON: [{"open":"11:30","close":"14:30"},{"open":"18:00","close":"23:00"}]
  sortOrder Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("opening_hours")
}

// ===================== LINKTREE =====================
model LinktreeSettings {
  id              Int     @id @default(1)
  coverImageUrl   String?
  coverVideoUrl   String?
  coverType       String  @default("image") // "image" | "video" | "color"
  coverColor      String  @default("#111827")
  bgColor         String  @default("#111827")
  bgImageUrl      String?
  profileName     String  @default("Woodiz Paris 15")
  profileSubtitle String?
  profileImageUrl String?
  noticeText      String?
  noticeIcon      String?
  showHours       Boolean @default(true)
  showFaqs        Boolean @default(true)
  showPromos      Boolean @default(true)
  showNotif       Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("linktree_settings")
}

model LinktreeButton {
  id          Int     @id @default(autoincrement())
  label       String
  url         String
  icon        String? // SVG string or icon name
  iconUrl     String?
  bgColor            String  @default("#F59E0B")
  bgGradient         String? // CSS gradient, e.g. "linear-gradient(135deg, #F59E0B, #EF4444)"
  textColor          String  @default("#FFFFFF")
  borderColor        String?
  style              String  @default("filled") // "filled" | "outline" | "ghost"
  labelTranslations  String? // JSON: {"fr":"Commander","en":"Order","it":"Ordina","es":"Pedir"}
  isVisible   Boolean @default(true)
  sortOrder   Int     @default(0)
  section     String  @default("main") // section label for grouping
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("linktree_buttons")
}

// ===================== MENU =====================
model MenuCategory {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  iconUrl     String?
  iconEmoji   String?
  bgColor     String?
  isVisible   Boolean       @default(true)
  sortOrder   Int           @default(0)
  translations MenuCategoryTranslation[]
  products    MenuItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("menu_categories")
}

model MenuCategoryTranslation {
  id         Int          @id @default(autoincrement())
  categoryId Int
  locale     String       // "fr", "en", "it", "es"
  name       String
  description String?
  category   MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@map("menu_category_translations")
}

model MenuItem {
  id           Int      @id @default(autoincrement())
  categoryId   Int
  slug         String   @unique
  imageUrl     String?
  price        Decimal  @db.Decimal(10, 2)
  comparePrice Decimal? @db.Decimal(10, 2)
  allergens    String?  // JSON array: ["gluten", "lactose", "eggs"]
  badges       String?  // JSON array: ["bestseller", "nouveau", "veggie", "piment"]
  isVisible    Boolean  @default(true)
  isOutOfStock Boolean  @default(false)
  isFeatured   Boolean  @default(false)
  isWeekSpecial Boolean @default(false)
  sortOrder    Int      @default(0)
  category     MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations MenuItemTranslation[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("menu_items")
}

model MenuItemTranslation {
  id          Int      @id @default(autoincrement())
  itemId      Int
  locale      String
  name        String
  description String?  @db.Text
  item        MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, locale])
  @@map("menu_item_translations")
}

// ===================== PROMOTIONS =====================
model Promotion {
  id              Int      @id @default(autoincrement())
  type            String   @default("delivery") // "delivery" | "takeaway" | "onsite" | "all"
  bgType          String   @default("color") // "color" | "image" | "gradient"
  bgColor         String   @default("#F59E0B")
  bgGradient      String?  // CSS gradient string
  bgImageUrl      String?
  textColor       String   @default("#FFFFFF")
  badgeText       String?  // "MENU MIDI", "OFFRE À EMPORTER"
  badgeColor      String   @default("#EF4444")
  originalPrice   Decimal? @db.Decimal(10, 2)
  promoPrice      Decimal? @db.Decimal(10, 2)
  photoOnly       Boolean  @default(false)
  isVisible       Boolean  @default(true)
  showOnLinktree  Boolean  @default(true)
  showOnMenu      Boolean  @default(true)
  sortOrder       Int      @default(0)
  startsAt        DateTime?
  endsAt          DateTime?
  translations    PromotionTranslation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("promotions")
}

model PromotionTranslation {
  id          Int       @id @default(autoincrement())
  promotionId Int
  locale      String
  title       String
  description String?   @db.Text
  cta         String?
  ctaUrl      String?
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@unique([promotionId, locale])
  @@map("promotion_translations")
}

// ===================== FAQS =====================
model FAQ {
  id           Int              @id @default(autoincrement())
  isVisible    Boolean          @default(true)
  showOnLinktree Boolean        @default(true)
  showOnMenu   Boolean          @default(true)
  sortOrder    Int              @default(0)
  translations FAQTranslation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("faqs")
}

model FAQTranslation {
  id       Int    @id @default(autoincrement())
  faqId    Int
  locale   String
  question String
  answer   String @db.Text
  faq      FAQ    @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
  @@map("faq_translations")
}

// ===================== REVIEWS =====================
model Review {
  id         Int      @id @default(autoincrement())
  authorName String
  authorInitial String?
  avatarColor String  @default("#F59E0B")
  rating     Int      @default(5)
  text       String   @db.Text
  source     String   @default("google") // "google" | "manual"
  date       DateTime @default(now())
  isVisible  Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("reviews")
}

// ===================== NOTIFICATION BAR =====================
model NotificationBar {
  id        Int     @id @default(1)
  isVisible Boolean @default(true)
  bgColor   String  @default("#1F2937")
  textColor String  @default("#F59E0B")
  icon      String?
  link      String?
  linkLabel String?
  translations NotificationBarTranslation[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_bar")
}

model NotificationBarTranslation {
  id     Int             @id @default(autoincrement())
  barId  Int
  locale String
  text   String
  bar    NotificationBar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@unique([barId, locale])
  @@map("notification_bar_translations")
}

// ===================== FOOTER =====================
model FooterSettings {
  id          Int    @id @default(1)
  bgColor     String @default("#1C1209")
  textColor   String @default("#9CA3AF")
  accentColor String @default("#F59E0B")
  col1Json    String @db.Text // JSON: {title, items:[{label,url}]}
  col2Json    String @db.Text
  col3Json    String @db.Text
  col4Json    String @db.Text
  copyright   String @default("© 2024 Woodiz. Tous droits réservés.")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("footer_settings")
}

// ===================== ADMIN USER =====================
model AdminUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_users")
}
